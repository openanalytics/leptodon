pipeline {
  agent {
    kubernetes {
      inheritFrom 'kaniko'
      yamlFile 'agent.pod.yaml'
      defaultContainer 'leptodon-build'
      yamlMergeStrategy merge()
    }
  }
  options {
    buildDiscarder(logRotator(numToKeepStr: '3'))
  }
  environment {
    CONFIGURE_GIT = sh(
      returnStdout: true,
      script: 'git config --global safe.directory "*"'
    ).trim()
    VERSION = sh(
      returnStdout: true,
      script: 'nix develop ./nix --quiet --quiet --command cargo metadata --no-deps --format-version=1 | nix develop ./nix --quiet --quiet --command jq ".packages[0].version" --raw-output'
    ).trim()
    NIX_PATH = 'nixpkgs=channel:nixos-unstable'
    NS = 'openanalytics'
    REGISTRY = 'registry.openanalytics.eu'
    IMAGE = 'leptodon'
    CACHE_IMAGE = 'leptodon-cache'
    DOCKER_BUILDKIT = '1'
    NO_COLOR = 'true'
  }
  stages {
    stage('Prepare Environment') {
      steps {
        script {
          if (env.BRANCH_NAME == 'develop') {
            env.TAG = "${env.VERSION}-SNAPSHOT"
          } else {
            env.TAG = "${env.VERSION}"
          }
          echo "TAG is set to ${env.TAG}"
        }
      }
    }
    stage('Cargo available ?') {
        steps {
            sh "nix develop ./nix --command cargo --version"
            sh "nix-env -i attic_client"
            withCredentials([usernamePassword(credentialsId: 'attic-leptodon', passwordVariable: 'ATTIC_PASSWORD', usernameVariable: 'ATTIC_USERNAME')]) {
                sh "attic login $ATTIC_USERNAME https://nix-cache.dev.openanalytics.eu $ATTIC_PASSWORD"
            }
            sh "attic use oa-leptodon"
            sh "nix build ./flake-modules/crates#demo-site-image"
        }
    }
    stage('Publish Demo') {
      when {
        anyOf {
          branch 'develop'
          branch 'main'
        }
      }
      steps {
        container('kaniko') {
          sh """
          ls -al result
          """
        }
      }
      post {
        always {
          sh "cp /kaniko/jenkins/mem*.log ${env.WORKSPACE}"
          archiveArtifacts artifacts: 'mem*.log', fingerprint: true
        }
      }
    }
  }
}
