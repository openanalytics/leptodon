pipeline {
  agent {
    kubernetes {
      inheritFrom 'kaniko'
      yamlFile 'agent.pod.yaml'
      defaultContainer 'leptodon-build'
      yamlMergeStrategy merge()
    }
  }
  options {
    buildDiscarder(logRotator(numToKeepStr: '3'))
  }
  environment {
    CONFIGURE_GIT = sh(
      returnStdout: true,
      script: 'git config --global safe.directory "*"'
    ).trim()
    VERSION = sh(
      returnStdout: true,
      script: 'cat Cargo.toml | tomlq ".workspace.package.version" --raw-output'
    ).trim()
    NIX_PATH = 'nixpkgs=channel:nixos-unstable'
    NS = 'openanalytics'
    REGISTRY = 'registry.openanalytics.eu'
    IMAGE = 'leptodon'
    CACHE_IMAGE = 'leptodon-cache'
    DOCKER_BUILDKIT = '1'
    NO_COLOR = 'true'
  }
  stages {
    stage('Prepare Environment') {
      steps {
        script {
          if (env.BRANCH_NAME == 'develop') {
            env.TAG = "${env.VERSION}-SNAPSHOT"
          } else {
            env.TAG = "${env.VERSION}"
          }
          echo "TAG is set to ${env.TAG}"
        }
        sh "chown -R root:root ."
      }
    }
    stage('Attic login & watch') {
      steps {
        sh 'echo "34.254.122.57 nix-cache.dev.openanalytics.eu" >> /etc/hosts'
        withCredentials([usernamePassword(credentialsId: 'attic-leptodon', passwordVariable: 'ATTIC_PASSWORD', usernameVariable: 'ATTIC_USERNAME')]) {
          sh "attic login $ATTIC_USERNAME https://nix-cache.dev.openanalytics.eu $ATTIC_PASSWORD"
        }
        sh "attic use oa-leptodon"
        sh "attic watch-store oa-leptodon &"
      }
    }
    stage('Compile deps') {
      steps {
        parallel(
          cargoArtifacts: {
            sh "nix build ./flake-modules/crates#cargoArtifacts -o cargoArtifacts"
            sh "cp cargoArtifacts/target.tar.zst ./target1.tar.zst"
            sh "zstd -d target1.tar.zst -o target1.tar"
            sh "tar xf target1.tar"
            sh "rm target1.tar CACHEDIR.TAG .rustc_info.json"
          },
          cargoWasmArtifacts: {
            sh "nix build ./flake-modules/crates#cargoWasmArtifacts -o cargoWasmArtifacts"
            sh "cp cargoWasmArtifacts/target.tar.zst ./target2.tar.zst"
            sh "zstd -d target2.tar.zst -o target2.tar"
            sh "tar xf target2.tar"
            sh "rm target2.tar CACHEDIR.TAG .rustc_info.json"
          }
        )
      }
    }
    stage('Library Unit Tests') {
      steps {
        sh "nix develop ./nix cargo make unit-tests"
        withChecks('Unit Tests') {
          junit "target/nextest/default/junit.xml"
        }
      }
    }
    stage('Integration Tests') {
      steps {
        sh "nix develop ./nix cargo make integration-tests"
        withChecks('Integration Tests') {
          junit "overview/end2end/reports/test-report-e2e.xml"
        }
      }
    }
    stage('Build & Publish Demo') {
      steps {
        // Skopeo policy
        sh """
          mkdir -p /etc/containers
          echo '{"default":[{"type":"insecureAcceptAnything"}],"transports":{"docker-daemon":{"":[{"type":"insecureAcceptAnything"}]}}}' > /etc/containers/policy.json
        """

        sh """
          nix build ./flake-modules/crates#demo-site-image
          cp result demo-image.tar.gz
          gunzip demo-image.tar.gz
          du -sh /nix/store
        """

        sh "nix develop ./nix --command skopeo login --authfile /root/.docker/config.json registry.openanalytics.eu "

        sh """
          du -sh /nix/store
          nix develop ./nix --command skopeo copy \
            docker-archive:demo-image.tar \
            docker://registry.openanalytics.eu/openanalytics/leptodon-demo
          du -sh /nix/store
        """
      }
    }
    stage('Packaging') {
      when {
        expression { env.VERSION && !env.VERSION.contains("dev") }
      }
      stages {
        stage('Package leptodon-proc-macros') {
          steps {
            sh """
              cargo package -p leptodon-proc-macros;
            """
          }
          post {
            success {
              sh "cp target/package/*.crate ${env.WORKSPACE}"
              archiveArtifacts artifacts: '*.crate', fingerprint: true
            }
          }
        }
        stage('Publish leptodon-proc-macros') {
          when {
            branch 'main'
          }
          environment {
            CARGO_REGISTRY_TOKEN = credentials('cratesio-oajenkins')
          }
          steps {
            sh "cargo make publish-leptodon-proc-macros-if-missing"
          }
        }
        stage('Package Leptodon') {
          when {
            // Avoid failures on develop when bumping the proc-macros crate version
            branch 'main'
          }
          steps {
            retry(3) {
              // Pray crates.io finds the newly published crate version after 15s.
              sh """
                sleep 5;
                cargo package -p leptodon;
              """
            }
          }
          post {
            success {
              sh "cp target/package/*.crate ${env.WORKSPACE}"
              archiveArtifacts artifacts: '*.crate', fingerprint: true
            }
          }
        }
        stage('Publish Leptodon Crate') {
          when {
            branch 'main'
          }
          environment {
            CARGO_REGISTRY_TOKEN = credentials('cratesio-oajenkins')
          }
          steps {
            sh "cargo make publish-leptodon-if-missing"
          }
        }
      }
    }
  }
}
