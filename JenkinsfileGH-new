pipeline {
  agent {
    kubernetes {
      inheritFrom 'kaniko'
      yamlFile 'agent.pod.yaml'
      defaultContainer 'leptodon-build'
      yamlMergeStrategy merge()
    }
  }
  options {
    buildDiscarder(logRotator(numToKeepStr: '3'))
  }
  environment {
    CONFIGURE_GIT = sh(
      returnStdout: true,
      script: 'git config --global safe.directory "*"'
    ).trim()
    VERSION = sh(
      returnStdout: true,
      script: 'tomlq --raw-output ".workspace.package.version" Cargo.toml'
    ).trim()
    NIX_PATH = 'nixpkgs=channel:nixos-unstable'
    NS = 'openanalytics'
    REGISTRY = 'registry.openanalytics.eu'
    IMAGE = 'leptodon'
    CACHE_IMAGE = 'leptodon-cache'
    DOCKER_BUILDKIT = '1'
    NO_COLOR = 'true'

    KEYCLOAK_URL = 'https://sso.openanalytics.eu/auth'
    REALM = 'openanalytics'
    CLIENT_ID = 'nix-cache'
    TOKEN_ENDPOINT = "${KEYCLOAK_URL}/realms/${REALM}/protocol/openid-connect/token"
  }
  stages {
    stage('Prepare Environment') {
      steps {
        script {
          if (env.BRANCH_NAME == 'develop') {
            env.TAG = "${env.VERSION}-SNAPSHOT"
          } else {
            env.TAG = "${env.VERSION}"
          }
          echo "TAG is set to ${env.TAG}"
        }
        sh "chown -R root:root ."
      }
    }
    stage('Attic login & watch') {
      steps {
        withCredentials([string(credentialsId: 'nix-cache-secret', variable: 'CLIENT_SECRET')]) {
          sh """
            nix run nixpkgs#curl -- -s -X POST "${env.TOKEN_ENDPOINT}" \
              -H "Content-Type: application/x-www-form-urlencoded" \
              -d "grant_type=client_credentials" \
              -d "client_id=${env.CLIENT_ID}" \
              -d "client_secret=\$CLIENT_SECRET" \
              -o .tmp_response
          """
        }
        sh """
          set +x
          attic login oa-leptodon https://nix-cache.openanalytics.eu `jq -r ".access_token // empty" .tmp_response`
          set -x
        """
        sh "rm .tmp_response"
        sh "attic use oa-leptodon"
        sh "attic watch-store oa-leptodon &"
      }
    }
    stage('Compile deps') {
      steps {
        parallel(
          cargoArtifacts: {
            sh "nix build ./flake-modules/crates#cargoArtifacts"
          },
          cargoWasmArtifacts: {
            sh "nix build ./flake-modules/crates#cargoWasmArtifacts"
          }
        )
      }
    }
    stage('Run Tests') {
      parallel {
        stage('Unit Tests') {
          steps {
            sh "nix build ./flake-modules/crates#nextest -o nextest-result"
            sh "ls -Hal nextest-result"
            withChecks('Unit Tests') {
              sh "cp nextest-result/junit.xml ${env.WORKSPACE}"
              junit "junit.xml"
            }
          }
        }
        stage('Integration Tests') {
          environment {
            LEPTOS_SITE_ADDR="0.0.0.0:3000"
          }
          steps {
            sh "nix build ./flake-modules/crates#overview-site -o overview-site-result"
            sh """
              ./overview-site-result/bin/overview-site &

              echo "Up and running";
              cd overview/end2end;
              nix develop -c npm install;
              CI=1 nix develop -c npx playwright test;

              # Kills whatever this script spawned
              kill \$! && echo "killed server";
            """
            withChecks('Integration Tests') {
              junit "overview/end2end/reports/test-report-e2e.xml"
            }
          }
        }
        stage('Build Demo') {
          steps {
            sh """
              nix build ./flake-modules/crates#demo-site-image
              cp result demo-image.tar.gz
              gunzip demo-image.tar.gz
            """
          }
        }
      }
    }
    stage('Publish Demo') {
      steps {
        // Skopeo policy
        sh """
          mkdir -p /etc/containers
          echo '{"default":[{"type":"insecureAcceptAnything"}],"transports":{"docker-daemon":{"":[{"type":"insecureAcceptAnything"}]}}}' > /etc/containers/policy.json
        """

        sh "nix develop ./nix --command skopeo login --authfile /root/.docker/config.json registry.openanalytics.eu "

        sh """
          du -sh /nix/store
          nix develop ./nix --command skopeo copy \
            docker-archive:demo-image.tar \
            docker://registry.openanalytics.eu/openanalytics/leptodon-demo:latest
          nix develop ./nix --command skopeo copy \
            docker://registry.openanalytics.eu/openanalytics/leptodon-demo:latest \
            docker://registry.openanalytics.eu/openanalytics/leptodon-demo:$VERSION
          du -sh /nix/store
        """
      }
    }
    stage('Packaging') {
      when {
        expression { env.VERSION && !env.VERSION.contains("dev") }
      }
      stages {
        stage('Package leptodon-proc-macros') {
          steps {
            sh """
              nix develop ./nix --command cargo package -p leptodon-proc-macros;
            """
          }
          post {
            success {
              sh "cp target/package/*.crate ${env.WORKSPACE}"
              archiveArtifacts artifacts: '*.crate', fingerprint: true
            }
          }
        }
        stage('Publish leptodon-proc-macros') {
          when {
            branch 'main'
          }
          environment {
            CARGO_REGISTRY_TOKEN = credentials('cratesio-oajenkins')
          }
          steps {
            sh "nix develop ./nix --command cargo make publish-leptodon-proc-macros-if-missing"
          }
        }
        stage('Package Leptodon') {
          when {
            // Avoid failures on develop when bumping the proc-macros crate version
            branch 'main'
          }
          steps {
            retry(3) {
              // Pray crates.io finds the newly published crate version after 15s.
              sh """
                sleep 5;
                nix develop ./nix --command cargo package -p leptodon;
              """
            }
          }
          post {
            success {
              sh "cp target/package/*.crate ${env.WORKSPACE}"
              archiveArtifacts artifacts: '*.crate', fingerprint: true
            }
          }
        }
        stage('Publish Leptodon Crate') {
          when {
            branch 'main'
          }
          environment {
            CARGO_REGISTRY_TOKEN = credentials('cratesio-oajenkins')
          }
          steps {
            sh "nix develop ./nix --command cargo make publish-leptodon-if-missing"
          }
        }
      }
    }
  }
}
