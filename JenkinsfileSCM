pipeline {
  agent {
    kubernetes {
      inheritFrom 'kaniko'
      yamlFile 'agent.pod.yaml'
      defaultContainer 'leptos-components-build'
      yamlMergeStrategy merge()
    }
  }
  options {
    buildDiscarder(logRotator(numToKeepStr: '3'))
  }
  environment {
    VERSION = sh(
      returnStdout: true,
      script: 'cargo metadata --no-deps --format-version=1 | jq ".packages[0].version" --raw-output'
    ).trim()
    NS = 'openanalytics'
    REGISTRY = 'registry.openanalytics.eu'
    IMAGE = 'leptos-components'
    CACHE_IMAGE = 'leptos-components-cache'
    DOCKER_BUILDKIT = '1'
    NO_COLOR = 'true'
  }
  stages {
    stage('Prepare Environment') {
      steps {
        script {
          if (env.BRANCH_NAME == 'develop') {
            env.TAG = "${env.VERSION}-SNAPSHOT"
          } else {
            env.TAG = "${env.VERSION}"
          }
          echo "TAG is set to ${env.TAG}"
        }
        timestamps {
          // Download and extract cache
          sh "aws s3 cp s3://oa-infrastructure-cache/${IMAGE}/${env.BRANCH_NAME}/cache.tar ${env.WORKSPACE}/cache.tar --region eu-west-1 --quiet || echo 'Failed downloading cache'"
          sh "tar -Pxf cache.tar || echo 'Failed extracting cache'"
        }
      }
    }
    stage('Linting') {
      steps {
	      sh "cargo make lint"
      }
    }
    stage('Library Unit Tests') {
      steps {
        sh "cargo make unit-tests"
        withChecks('Unit Tests') {
          junit "target/nextest/default/junit.xml"
        }
      }
    }
    stage('Integration Tests') {
      steps {
        sh "cargo make integration-tests"
        withChecks('Integration Tests') {
          junit "overview/end2end/reports/test-report-e2e.xml"
        }
      }
    }
    stage('Publish Demo') {
      when {
        anyOf {
          branch 'develop'
          branch 'main'
        }
      }
      steps {
        container('kaniko') {
          sh """
          /kaniko/executor \
            -v info \
            --context ${env.WORKSPACE} \
            --cache=true \
            --cache-repo ${env.REGISTRY}/${env.NS}/${env.CACHE_IMAGE}-demo \
            --destination ${env.REGISTRY}/${env.NS}/${env.IMAGE}-demo:${env.TAG} \
            --log-format=text \
            --log-timestamp=true \
            --dockerfile demo.Dockerfile
          """
        }
      }
      post {
        always {
          sh "cp /kaniko/jenkins/mem*.log ${env.WORKSPACE}"
          archiveArtifacts artifacts: 'mem*.log', fingerprint: true

          sh "tar -Pcf cache.tar ./target ${env.WORKSPACE}/overview/target ${env.WORKSPACE}/demo/target ${env.WORKSPACE}/overview/codegen/target ${env.WORKSPACE}/attr-docgen/target ${env.WORKSPACE}/demo/codegen/target /usr/local/cargo/git /usr/local/cargo/registry"
          sh "aws s3 cp ${env.WORKSPACE}/cache.tar s3://oa-infrastructure-cache/${IMAGE}/${env.BRANCH_NAME}/cache.tar --region eu-west-1 --quiet"
          sh "du -sch cache.tar"
        }
      }
    }
  }
}
